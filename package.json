{
    "private": true,
    "type": "module",
    "engines": {
        "node": ">=24.0.0"
    },
    "scripts": {
        "preinstall": "npx only-allow bun",
        "build": "vp build && vp check",
        "build:ssr": "vp build && vp build --ssr",
        "dev": "vp dev",
        "lint": "NODE_OPTIONS='--experimental-strip-types' vp fmt resources/ && NODE_OPTIONS='--experimental-strip-types' vp lint --fix",
        "test:lint": "NODE_OPTIONS='--experimental-strip-types' vp fmt --check resources/ && NODE_OPTIONS='--experimental-strip-types' vp lint",
        "test:types": "tsc --noEmit",
        "test:ui": "vitest run",
        "test:ui:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "prepare": "vp config || true",
        "postinstall": "[ \"$PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD\" = \"1\" ] || playwright install chromium"
    },
    "devDependencies": {
        "@laravel/vite-plugin-wayfinder": "^0.1.7",
        "@rolldown/plugin-babel": "^0.2.3",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^25.6.0",
        "@vitest/coverage-v8": "^4.1.5",
        "babel-plugin-react-compiler": "^1.0.0",
        "jsdom": "^29.0.2",
        "npm-check-updates": "^21.0.3",
        "playwright": "^1.59.1",
        "tw-animate-css": "^1.4.0",
        "vite": "npm:@voidzero-dev/vite-plus-core@latest",
        "vite-plus": "^0.1.19",
        "vitest": "^4.1.5"
    },
    "dependencies": {
        "@base-ui/react": "^1.4.1",
        "@fontsource-variable/ibm-plex-sans": "^5.2.8",
        "@fontsource-variable/inter": "^5.2.8",
        "@fontsource-variable/noto-sans": "^5.2.10",
        "@inertiajs/react": "^3.0.3",
        "@inertiajs/vite": "^3.0.3",
        "@tailwindcss/vite": "^4.2.4",
        "@tanstack/react-form": "^1.29.1",
        "@tanstack/react-table": "^8.21.3",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "concurrently": "^9.2.1",
        "date-fns": "^4.1.0",
        "input-otp": "^1.4.2",
        "laravel-vite-plugin": "^3.0.1",
        "lucide-react": "^1.11.0",
        "next-themes": "^0.4.6",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-image-crop": "^11.0.10",
        "recharts": "3.8.1",
        "shadcn": "^4.4.0",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.4",
        "tailwindcss-animate": "^1.0.7",
        "typescript": "^6.0.3",
        "vaul": "^1.1.2",
        "zod": "^4.3.6"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "4.60.2",
        "@tailwindcss/oxide-linux-x64-gnu": "^4.2.4",
        "lightningcss-linux-x64-gnu": "^1.32.0"
    }
}
